# ─── Postgres ───
# Local dev (Postgres jalan di Mac via Homebrew):
DATABASE_URL=postgresql://idea@localhost:5432/ecc_finance

# Nanti untuk VPS, ganti host/credential. Format: postgresql://user:pass@host:5432/dbname

# ─── Session ───
# Generate: openssl rand -hex 32
SESSION_SECRET=ganti-dengan-string-random-64-char-hex

# ─── App ───
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── File storage ───
UPLOAD_DIR=./uploads

# ─── Optional (untuk milestone berikutnya) ───
# ANTHROPIC_API_KEY=sk-ant-...
