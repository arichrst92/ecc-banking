# ─── Postgres ───
# Local dev (Postgres jalan di Mac via Homebrew):
DATABASE_URL=postgresql://idea@localhost:5432/ecc_finance

# Nanti untuk VPS, ganti host/credential. Format: postgresql://user:pass@host:5432/dbname

# ─── Session ───
# Generate: openssl rand -hex 32
SESSION_SECRET=ganti-dengan-string-random-64-char-hex

# ─── App ───
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── File storage ───
UPLOAD_DIR=./uploads

# ─── Anthropic API ───
# Untuk schema-based parser learner (fallback kalau format tidak dikenal).
# Get key dari console.anthropic.com. Default model: claude-haiku-4-5.
ANTHROPIC_API_KEY=sk-ant-...

# Model untuk parser learning. Haiku cukup untuk struktur tabel.
PARSER_LLM_MODEL=claude-haiku-4-5-20251001
PARSER_LLM_MAX_TOKENS=8000
