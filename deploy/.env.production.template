# Template untuk .env.local di VPS production.
# Copy ke project root sebagai .env.local lalu isi value-nya.
#
# Lokasi password DB di-generate oleh server-setup.sh:
#   ~/.ecc-finance-db-password

# ─── Postgres ───
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Ganti $DB_PASS dengan isi file ~/.ecc-finance-db-password
DATABASE_URL=postgresql://ecc:GANTI_DENGAN_DB_PASSWORD@localhost:5432/ecc_finance

# ─── Session ───
# Generate sekali untuk production:
#   openssl rand -hex 32
SESSION_SECRET=GANTI_DENGAN_64_HEX_RANDOM_STRING

# ─── App ───
NEXT_PUBLIC_APP_URL=https://finance.eccchurch.global
NODE_ENV=production

# ─── File storage ───
# Direktori untuk upload file mutasi (di-create oleh server-setup.sh)
UPLOAD_DIR=/var/www/ecc-finance-uploads

# ─── Anthropic API (parser learning + AI categorization) ───
# Dari console.anthropic.com — KEEP SECRET
ANTHROPIC_API_KEY=sk-ant-...
PARSER_LLM_MODEL=claude-haiku-4-5-20251001
PARSER_LLM_MAX_TOKENS=8000
